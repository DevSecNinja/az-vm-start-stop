{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    ":dependencyDashboard",
    ":semanticCommits",
    "github>DevSecNinja/.github//.renovate/autoMerge.json5",
    "github>DevSecNinja/.github//.renovate/base.json5",
    "github>DevSecNinja/.github//.renovate/customManagers.json5",
    "github>DevSecNinja/.github//.renovate/groups.json5",
    "github>DevSecNinja/.github//.renovate/labels.json5",
    "github>DevSecNinja/.github//.renovate/packageRules.json5",
    "github>DevSecNinja/.github//.renovate/semanticCommits.json5",
  ],
  packageRules: [
    {
      // Microsoft releases this Functions Worker timer-trigger extension
      // infrequently, so Renovate flags 4.3.1 as "abandoned" by release
      // inactivity. It is the current, required package for timer triggers —
      // suppress the abandonment notice so it stops recurring on the dashboard.
      matchDatasources: ["nuget"],
      matchPackageNames: ["Microsoft.Azure.Functions.Worker.Extensions.Timer"],
      abandonmentThreshold: "10 years",
    },
    {
      // Microsoft.ApplicationInsights.WorkerService 3.x (Application Insights
      // SDK 3.x) is incompatible with the Functions Worker App Insights
      // integration (Microsoft.Azure.Functions.Worker.ApplicationInsights): AI
      // 3.x removed Microsoft.ApplicationInsights.Extensibility.ITelemetryInitializer,
      // so ConfigureFunctionsApplicationInsights throws TypeLoadException and the
      // worker aborts at startup (exit code 134). Stay on 2.x until the worker
      // integration supports AI 3.x.
      matchDatasources: ["nuget"],
      matchPackageNames: ["Microsoft.ApplicationInsights.WorkerService"],
      allowedVersions: "<3.0.0",
    },
  ],
}